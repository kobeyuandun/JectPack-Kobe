<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/doubao_voice_call_bg">

        <!-- 顶部栏 -->
        <LinearLayout
            android:id="@+id/ll_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 左侧：更多选项 -->
            <ImageView
                android:id="@+id/iv_more"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_doubao_more"
                app:tint="#CC333333" />

            <!-- 中间：春节限定模式徽章 -->
            <LinearLayout
                android:id="@+id/ll_spring_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/doubao_spring_badge_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_firecracker"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_doubao_firecracker" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="春节限定模式"
                    android:textColor="#CC333333"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 右侧：文字模式 -->
            <TextView
                android:id="@+id/tv_text_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字"
                android:textColor="#CC333333"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="4dp" />
        </LinearLayout>

        <!-- 中心圆形动效容器 - 豆包风格 -->
        <FrameLayout
            android:id="@+id/fl_center_animation"
            android:layout_width="300dp"
            android:layout_height="300dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_hint_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed">

            <!-- 第一层波纹（最外层 - 粉色） -->
            <View
                android:id="@+id/ripple_layer_1"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center"
                android:background="@drawable/doubao_wave_1" />

            <!-- 第二层波纹（外层 - 粉紫） -->
            <View
                android:id="@+id/ripple_layer_2"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:background="@drawable/doubao_wave_2" />

            <!-- 第三层波纹（中层 - 紫色） -->
            <View
                android:id="@+id/ripple_layer_3"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:background="@drawable/doubao_wave_3" />

            <!-- 第四层波纹（内层 - 蓝紫） -->
            <View
                android:id="@+id/ripple_layer_4"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/doubao_wave_4" />

            <!-- 核心三色流动圆 -->
            <View
                android:id="@+id/core_circle"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:background="@drawable/doubao_core_gradient_flow" />

            <!-- 叠加层产生流动效果 -->
            <View
                android:id="@+id/core_circle_overlay"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:background="@drawable/doubao_core_gradient_flow2"
                android:alpha="0.6" />

        </FrameLayout>

        <!-- 提示文字 -->
        <TextView
            android:id="@+id/tv_hint_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="你可以开始说话"
            android:textColor="#80666666"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/fl_center_animation"
            app:layout_constraintBottom_toTopOf="@id/ll_control_buttons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- 底部控制按钮 -->
        <LinearLayout
            android:id="@+id/ll_control_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:paddingBottom="80dp"
            android:baselineAligned="false"
            app:layout_constraintBottom_toTopOf="@id/tv_ai_hint"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 麦克风按钮 -->
            <FrameLayout
                android:id="@+id/fl_mic"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center">

                <View
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/doubao_control_button_bg" />

                <ImageView
                    android:id="@+id/iv_mic"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_doubao_mic_large"
                    app:tint="#CC333333" />
            </FrameLayout>

            <!-- 上传按钮 -->
            <FrameLayout
                android:id="@+id/fl_upload"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center">

                <View
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/doubao_control_button_bg" />

                <ImageView
                    android:id="@+id/iv_upload"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_doubao_upload"
                    app:tint="#CC333333" />
            </FrameLayout>

            <!-- 视频按钮 -->
            <FrameLayout
                android:id="@+id/fl_video"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center">

                <View
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/doubao_control_button_bg" />

                <ImageView
                    android:id="@+id/iv_video"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_doubao_video"
                    app:tint="#CC333333" />
            </FrameLayout>

            <!-- 关闭按钮 -->
            <FrameLayout
                android:id="@+id/fl_close"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center">

                <View
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/doubao_close_button_bg" />

                <ImageView
                    android:id="@+id/iv_close"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_doubao_close"
                    app:tint="#FFFF4444" />
            </FrameLayout>
        </LinearLayout>

        <!-- AI 提示文字 -->
        <TextView
            android:id="@+id/tv_ai_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="内容由AI生成"
            android:textColor="#80666666"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
